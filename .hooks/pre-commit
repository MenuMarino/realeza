#!/bin/bash
# Compress any staged .mp4 files before committing

staged=$(git diff --cached --name-only --diff-filter=AM -- 'clips/*.mp4' 'clips/**/*.mp4')

if [ -z "$staged" ]; then
  exit 0
fi

if ! command -v ffmpeg &>/dev/null; then
  echo "⚠️  ffmpeg not found — skipping compression. Install it for smaller file sizes."
  exit 0
fi

for file in $staged; do
  [ ! -f "$file" ] && continue
  tmp="${file%.mp4}_compressed.mp4"
  echo "🎬 Compressing $file..."
  ffmpeg -i "$file" -vf "scale=-2:720" -c:v libx264 -crf 28 -preset fast -c:a aac -b:a 96k -y -loglevel warning "$tmp"
  if [ $? -eq 0 ]; then
    original=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file")
    compressed=$(stat -f%z "$tmp" 2>/dev/null || stat -c%s "$tmp")
    if [ "$compressed" -lt "$original" ]; then
      mv "$tmp" "$file"
      git add "$file"
      echo "   ✅ $(( original / 1024 ))KB → $(( compressed / 1024 ))KB"
    else
      rm "$tmp"
      echo "   ⏭️  Already small enough, skipping"
    fi
  else
    rm -f "$tmp"
    echo "   ⚠️  Compression failed, keeping original"
  fi
done
